generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MODEL USER
// ============================================================
model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  role            Role     @default(USER)
  isBanned        Boolean  @default(false)
  banReason       String?
  bannedAt        DateTime?
  suspendedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  metaAccounts MetaAccount[]
  auditLogs    AuditLog[]

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

// ============================================================
// MODEL META ACCOUNT
// ============================================================
model MetaAccount {
  id          Int      @id @default(autoincrement())
  userId      Int
  accessToken String   @db.Text
  accountId   String
  accountName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([userId, accountId])
  @@map("meta_accounts")
}

// ============================================================
// MODEL CAMPAIGN
// ============================================================
model Campaign {
  id              Int            @id @default(autoincrement())
  metaAccountId   Int
  metaCampaignId  String
  name            String
  status          CampaignStatus @default(ACTIVE)
  spend           Float          @default(0)
  ctr             Float          @default(0)
  roas            Float          @default(0)
  reach           Int            @default(0)
  date            DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  metaAccount      MetaAccount       @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  aiRecommendation AiRecommendation?

  @@unique([metaAccountId, metaCampaignId])
  @@map("campaigns")
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
}

// ============================================================
// MODEL AI RECOMMENDATION
// ============================================================
model AiRecommendation {
  id              Int      @id @default(autoincrement())
  campaignId      Int      @unique
  score           Int
  recommendations Json
  label           String   @default("Average")
  color           String   @default("#FFA500")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ai_recommendations")
}

// ============================================================
// MODEL AUDIT LOG
// ============================================================
model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  action        String   // LOGIN, LOGOUT, CREATE, UPDATE, DELETE, BAN, etc
  resourceType  String   // User, Campaign, MetaAccount, etc
  resourceId    String
  description   String   @db.Text
  ipAddress     String?
  userAgent     String?
  statusCode    Int?
  timestamp     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([timestamp])
}